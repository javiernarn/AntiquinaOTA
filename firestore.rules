rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // users/{uid}: activeSession, clients, lastClientId — the small
    // mirror the scheduler needs. Only the signed-in owner can read/write
    // their own doc; nobody can read anyone else's.
    match /users/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;

      // Push tokens for this trainee's devices.
      match /devices/{token} {
        allow read, write: if request.auth != null && request.auth.uid == uid;
      }

      // Which reminders already fired today — written only by Cloud
      // Functions (Admin SDK bypasses rules entirely), read-only for the
      // owner so the app could optionally show "already reminded" state.
      match /notifyState/{date} {
        allow read: if request.auth != null && request.auth.uid == uid;
        allow write: if false;
      }
    }
  }
}
